{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022-dev",
      "displayName": "Windows VS2022 Dev",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "PETERCRAFT_ENABLE_STRICT_WARNINGS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-dev-debug",
      "configurePreset": "windows-vs2022-dev",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vs2022-dev-debug",
      "configurePreset": "windows-vs2022-dev",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
