{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Logic Rules Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "rulesets"],
  "properties": {
    "kind": { "const": "logicRulesCatalog" },
    "schemaVersion": { "const": 4 },
    "rulesets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "cards"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "cards": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "conditionId", "actionId", "scoreDelta"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
                "conditionId": { "enum": ["player_health_low", "player_needs_revive", "rare_loot_visible", "extraction_active", "companion_health_low", "timed_pressure_high"] },
                "actionId": { "enum": ["prioritize_help", "prioritize_cover", "mark_rare_loot", "retreat_regroup", "hold_position", "favor_extraction"] },
                "scoreDelta": { "type": "number", "minimum": -20, "maximum": 20 }
              }
            }
          }
        }
      }
    }
  }
}
