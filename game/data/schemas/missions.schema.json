{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Mission Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "missions"],
  "properties": {
    "kind": { "const": "missionCatalog" },
    "schemaVersion": { "const": 1 },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "template", "entryRoomId", "extractionRoomId", "lootTableId"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "template": { "type": "string", "enum": ["extract", "tutorial", "salvage_run"] },
          "entryRoomId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "extractionRoomId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "lootTableId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" }
        }
      }
    }
  }
}
