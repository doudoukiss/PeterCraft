{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Mini Mission Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "miniMissions"],
  "properties": {
    "kind": { "const": "miniMissionCatalog" },
    "schemaVersion": { "const": 4 },
    "miniMissions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "roomBundleId", "lootGoalItemId", "enemyGroupId", "extractionPointId", "rewardBundleId", "revision"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "roomBundleId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "lootGoalItemId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "enemyGroupId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "extractionPointId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "rewardBundleId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "revision": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
