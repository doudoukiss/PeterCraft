{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Item Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "items"],
  "properties": {
    "kind": { "const": "itemCatalog" },
    "schemaVersion": { "const": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "category", "stackLimit", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "category": { "enum": ["salvage", "consumable", "tool", "gadget", "companion_module", "crafting_material"] },
          "stackLimit": { "type": "integer", "minimum": 1, "maximum": 999 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
