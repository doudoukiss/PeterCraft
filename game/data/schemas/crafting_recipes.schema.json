{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Crafting Recipes",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "recipes"],
  "properties": {
    "kind": { "const": "craftingRecipeCatalog" },
    "schemaVersion": { "const": 1 },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "inputItemId", "inputCount", "upgradeId", "capacityBonus"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "inputItemId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "inputCount": { "type": "integer", "minimum": 1 },
          "upgradeId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "capacityBonus": { "type": "integer", "minimum": 1, "maximum": 3 }
        }
      }
    }
  }
}
