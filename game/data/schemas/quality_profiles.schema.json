{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Phase 6 Quality Profile",
  "type": "object",
  "required": [
    "kind",
    "id",
    "display_name",
    "hardware_profile_id",
    "target_os",
    "cpu_class",
    "memory_gb",
    "storage_class",
    "gpu_class",
    "fps_target",
    "frame_time_p95_ms",
    "cold_boot_budget_ms",
    "transition_budget_ms",
    "peak_working_set_budget_mb",
    "ai_decision_p95_ms",
    "ui_panel_render_p95_ms",
    "single_save_budget_ms",
    "full_load_budget_ms",
    "full_save_budget_ms",
    "feedback_required_families",
    "feedback_priorities"
  ],
  "properties": {
    "kind": { "const": "qualityProfile" },
    "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "hardware_profile_id": { "type": "string", "minLength": 1 },
    "target_os": { "type": "string", "minLength": 1 },
    "cpu_class": { "type": "string", "minLength": 1 },
    "memory_gb": { "type": "string", "pattern": "^[0-9]+$" },
    "storage_class": { "type": "string", "minLength": 1 },
    "gpu_class": { "type": "string", "minLength": 1 },
    "fps_target": { "type": "string", "pattern": "^[0-9]+$" },
    "frame_time_p95_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "cold_boot_budget_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "transition_budget_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "peak_working_set_budget_mb": { "type": "string", "pattern": "^[0-9]+$" },
    "ai_decision_p95_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "ui_panel_render_p95_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "single_save_budget_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "full_load_budget_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "full_save_budget_ms": { "type": "string", "pattern": "^[0-9.]+$" },
    "movement_acceleration_mps2": { "type": "string", "pattern": "^[0-9.]+$" },
    "movement_deceleration_mps2": { "type": "string", "pattern": "^[0-9.]+$" },
    "movement_jump_readability_scale": { "type": "string", "pattern": "^[0-9.]+$" },
    "movement_jump_buffer_ms": { "type": "string", "pattern": "^[0-9]+$" },
    "movement_ledge_forgiveness_ms": { "type": "string", "pattern": "^[0-9]+$" },
    "movement_companion_spacing_m": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_smoothing_strength": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_sensitivity_curve_exponent": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_shoulder_offset_m": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_follow_distance_m": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_pitch_degrees": { "type": "string", "pattern": "^[0-9.]+$" },
    "camera_motion_comfort_enabled": { "type": "string", "enum": ["true", "false"] },
    "combat_telegraph_window_ms": { "type": "string", "pattern": "^[0-9]+$" },
    "combat_hit_stop_ms": { "type": "string", "pattern": "^[0-9]+$" },
    "combat_low_health_threshold": { "type": "string", "pattern": "^[0-9]+$" },
    "combat_line_of_fire_width_m": { "type": "string", "pattern": "^[0-9.]+$" },
    "combat_status_clarity_mode": { "type": "string", "minLength": 1 },
    "feedback_max_concurrent_world_cues": { "type": "string", "pattern": "^[0-9]+$" },
    "feedback_max_critical_cues_per_beat": { "type": "string", "pattern": "^[0-9]+$" },
    "feedback_required_families": { "type": "string", "minLength": 1 },
    "feedback_priorities": { "type": "string", "minLength": 1 },
    "subtitle_background_required": { "type": "string", "enum": ["true", "false"] },
    "high_contrast_required": { "type": "string", "enum": ["true", "false"] },
    "icon_redundancy_required": { "type": "string", "enum": ["true", "false"] },
    "motion_comfort_required": { "type": "string", "enum": ["true", "false"] }
  },
  "additionalProperties": false
}
