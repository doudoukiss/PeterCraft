{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Upgrade Tracks",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "tracks"],
  "properties": {
    "kind": { "const": "upgradeTrackCatalog" },
    "schemaVersion": { "const": 2 },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "summary", "nodes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "displayName", "description", "costItemId", "cost", "effectType", "effectValue"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
                "displayName": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "costItemId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
                "prerequisiteNodeId": { "type": "string", "pattern": "^$|^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
                "cost": { "type": "integer", "minimum": 1, "maximum": 10 },
                "effectType": { "type": "string", "minLength": 1 },
                "effectValue": { "type": "integer", "minimum": 0, "maximum": 10 }
              }
            }
          }
        }
      }
    }
  }
}
