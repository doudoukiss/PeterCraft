{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Carry Capacity Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "profiles"],
  "properties": {
    "kind": { "const": "carryCapacityCatalog" },
    "schemaVersion": { "const": 1 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "baseSlots", "allowedUpgradeIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "baseSlots": { "type": "integer", "minimum": 1, "maximum": 8 },
          "allowedUpgradeIds": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" }
          }
        }
      }
    }
  }
}
