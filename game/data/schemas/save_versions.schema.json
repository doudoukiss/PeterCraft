{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Save Version Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "domains"],
  "properties": {
    "kind": { "const": "saveVersionCatalog" },
    "schemaVersion": { "const": 1 },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "currentVersion", "minimumCompatibleVersion"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "currentVersion": { "type": "integer", "minimum": 1 },
          "minimumCompatibleVersion": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
