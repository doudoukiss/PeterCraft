{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Extraction Settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "settings"],
  "properties": {
    "kind": { "const": "extractionSettingsCatalog" },
    "schemaVersion": { "const": 1 },
    "settings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "missionId", "countdownSeconds", "successCueId", "failCueId"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "missionId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "countdownSeconds": { "type": "integer", "minimum": 3, "maximum": 10 },
          "successCueId": { "type": "string", "minLength": 1 },
          "failCueId": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
