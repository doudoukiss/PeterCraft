{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "display_name", "archetype", "connector_class", "width_meters", "depth_meters", "height_meters", "nav_expectation", "lighting_expectation", "review_record_id"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "display_name": {"type": "string", "minLength": 1},
    "archetype": {"type": "string", "minLength": 1},
    "connector_class": {"type": "string", "minLength": 1},
    "width_meters": {"type": "string", "pattern": "^[0-9]+$"},
    "depth_meters": {"type": "string", "pattern": "^[0-9]+$"},
    "height_meters": {"type": "string", "pattern": "^[0-9]+$"},
    "nav_expectation": {"type": "string", "minLength": 1},
    "lighting_expectation": {"type": "string", "minLength": 1},
    "review_record_id": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
