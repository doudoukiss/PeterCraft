{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Patrol Routes",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "routes"],
  "properties": {
    "kind": { "const": "patrolRouteCatalog" },
    "schemaVersion": { "const": 1 },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "nodeIds", "looped"],
        "properties": {
          "id": { "type": "string", "pattern": "^route\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "nodeIds": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "pattern": "^room\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$" }
          },
          "looped": { "type": "boolean" }
        }
      }
    }
  }
}
