{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Encounter Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "encounters"],
  "properties": {
    "kind": { "const": "encounterCatalog" },
    "schemaVersion": { "const": 1 },
    "encounters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roomId", "enemyFamily", "variants"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "roomId": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "enemyFamily": { "type": "string", "minLength": 1 },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["melee_chaser", "alarm_support"] }
          },
          "optional": { "type": "boolean" }
        }
      }
    }
  }
}
