{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Companion Rule Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "rules"],
  "properties": {
    "kind": { "const": "companionRuleCatalog" },
    "schemaVersion": { "const": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chipName", "priority", "editableVariable", "defaultValue"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "chipName": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
          "editableVariable": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "defaultValue": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
