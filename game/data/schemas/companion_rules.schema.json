{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Companion Behavior Chip Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "chips"],
  "properties": {
    "kind": { "const": "companionChipCatalog" },
    "schemaVersion": { "const": 2 },
    "chips": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "chipName",
          "editableVariable",
          "defaultValue",
          "minValue",
          "maxValue",
          "plainLanguage",
          "promiseText",
          "cautionText",
          "effectDescription"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^chip\\.[a-z0-9_]+$" },
          "chipName": { "type": "string", "minLength": 1 },
          "editableVariable": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "defaultValue": { "type": "number", "minimum": 0, "maximum": 10 },
          "minValue": { "type": "number", "minimum": 0, "maximum": 10 },
          "maxValue": { "type": "number", "minimum": 0, "maximum": 10 },
          "plainLanguage": { "type": "string", "minLength": 1 },
          "promiseText": { "type": "string", "minLength": 1 },
          "cautionText": { "type": "string", "minLength": 1 },
          "effectDescription": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
