{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Room Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "rooms"],
  "properties": {
    "kind": { "const": "roomCatalog" },
    "schemaVersion": { "const": 1 },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "theme", "connectorCount", "supportsExtraction"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "theme": { "type": "string", "minLength": 1 },
          "connectorCount": { "type": "integer", "minimum": 1, "maximum": 8 },
          "supportsExtraction": { "type": "boolean" }
        }
      }
    }
  }
}
