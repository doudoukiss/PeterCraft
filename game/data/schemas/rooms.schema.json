{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Room Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "rooms"],
  "properties": {
    "kind": { "const": "roomCatalog" },
    "schemaVersion": { "const": 1 },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "theme", "roomType", "landmarkLabel", "exits", "supportsExtraction"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "theme": { "type": "string", "minLength": 1 },
          "roomType": { "type": "string", "enum": ["entry", "corridor", "optional_loot", "combat", "reward", "connector", "extraction"] },
          "landmarkLabel": { "type": "string", "minLength": 1 },
          "exits": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" }
          },
          "optionalPath": { "type": "boolean" },
          "highRiskReward": { "type": "boolean" },
          "supportsExtraction": { "type": "boolean" }
        }
      }
    }
  }
}
