{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PeterCraft Tutorial Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "tutorials"],
  "properties": {
    "kind": { "const": "tutorialCatalog" },
    "schemaVersion": { "const": 2 },
    "tutorials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "summary", "replayable", "steps"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
          "displayName": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "replayable": { "type": "boolean" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "contains": {
              "type": "object",
              "properties": {
                "action": { "const": "complete_lesson" }
              },
              "required": ["action"]
            },
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "action", "prompt", "triggerEvent", "completionEvent", "targetId", "hintThreshold"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" },
                "action": {
                  "type": "string",
                  "enum": [
                    "show_prompt",
                    "highlight_target",
                    "wait_for_event",
                    "open_panel",
                    "grant_temp_item",
                    "launch_lesson_mission",
                    "show_why_panel",
                    "open_creator_panel",
                    "apply_tinker_preset",
                    "apply_logic_template",
                    "edit_script",
                    "run_script_validation",
                    "launch_creator_mission",
                    "show_replay",
                    "reset_creator_content",
                    "complete_lesson"
                  ]
                },
                "prompt": { "type": "string", "minLength": 1 },
                "triggerEvent": { "type": "string" },
                "completionEvent": { "type": "string" },
                "targetId": { "type": "string" },
                "hintThreshold": { "type": "integer", "minimum": 0, "maximum": 5 }
              }
            }
          }
        }
      }
    }
  }
}
